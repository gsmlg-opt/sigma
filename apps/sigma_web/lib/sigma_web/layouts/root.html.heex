<!DOCTYPE html>
<html lang="en" data-theme="sunshine">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      {assigns[:page_title] || "Sigma"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={DuskmoonBundler.static_path(Sigma.Web.Endpoint, "/assets/css/app.css")} />
    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="alternate icon" type="image/png" href={~p"/favicon.ico"} />
    <script defer phx-track-static type="module" src={~p"/assets/js/duskmoon_rich_elements.js"}>
    </script>
    <script defer phx-track-static type="module" src={DuskmoonBundler.static_path(Sigma.Web.Endpoint, "/assets/js/app.js")}></script>
  </head>
  <body class="bg-surface text-on-surface antialiased font-body">
    {@inner_content}
  </body>
</html>
